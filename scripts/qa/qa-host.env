# Sourced by scripts/qa/*.sh for QA server layout and laptop SSH tunnels.
# Override any value by exporting before `make start-qa`, or set in repo-root `.env`.
#
# When QA_SHARED_HOST=1 (DEX + cl8y-bridge-monorepo on one machine), default host ports
# avoid bridge’s LocalTerra remap (26658/1318) and common gRPC collisions — adjust if needed.

if [ "${QA_SHARED_HOST:-}" = "1" ]; then
  export DEX_TERRA_RPC_PORT="${DEX_TERRA_RPC_PORT:-26659}"
  export DEX_TERRA_LCD_PORT="${DEX_TERRA_LCD_PORT:-1319}"
  export DEX_TERRA_GRPC_PORT="${DEX_TERRA_GRPC_PORT:-9094}"
  export DEX_TERRA_GRPC_WEB_PORT="${DEX_TERRA_GRPC_WEB_PORT:-9095}"
else
  export DEX_TERRA_RPC_PORT="${DEX_TERRA_RPC_PORT:-26657}"
  export DEX_TERRA_LCD_PORT="${DEX_TERRA_LCD_PORT:-1317}"
  export DEX_TERRA_GRPC_PORT="${DEX_TERRA_GRPC_PORT:-9090}"
  export DEX_TERRA_GRPC_WEB_PORT="${DEX_TERRA_GRPC_WEB_PORT:-9091}"
fi

export TERRA_RPC_URL="${TERRA_RPC_URL:-http://127.0.0.1:${DEX_TERRA_RPC_PORT}}"
export TERRA_LCD_URL="${TERRA_LCD_URL:-http://127.0.0.1:${DEX_TERRA_LCD_PORT}}"

export API_PORT="${API_PORT:-3001}"
