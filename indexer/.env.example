# Required
DATABASE_URL=postgres://postgres:postgres@localhost:5432/dex_indexer
FACTORY_ADDRESS=terra1factory...
CORS_ORIGINS=https://dex.cl8y.com,http://localhost:5173

# Deployment profile: unset or dev = public LCD fallbacks OK; prod = explicit operator LCDs required
# RUN_MODE=prod

# LCD (comma-separated). In prod, set operator-controlled URLs (not the built-in public defaults).
LCD_URLS=https://terra-classic-lcd.publicnode.com,https://columbus-lcd.terra.dev

# Optional registry + tuning
FEE_DISCOUNT_ADDRESS=terra1feediscount...
POLL_INTERVAL_MS=6000
API_PORT=3001
API_BIND=127.0.0.1
LCD_TIMEOUT_MS=8000
LCD_COOLDOWN_MS=30000
START_BLOCK=
RATE_LIMIT_RPS=60
ORACLE_POLL_INTERVAL_MS=30000

# Router for route/solve LCD simulate (optional; enables estimated_amount_out / hybrid merge quotes)
# ROUTER_ADDRESS=terra1router...

# Native denom for USTC oracle labeling (optional)
# USTC_DENOM=uusd

# Non-empty enables Prometheus metrics on the API server (bind address is read by deployment wiring)
# METRICS_BIND=127.0.0.1:9090

# For integration tests
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/dex_indexer_test
