# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/dex_indexer

# LCD endpoints (comma-separated, tried in order with fallback)
LCD_URLS=https://terra-classic-lcd.publicnode.com,https://columbus-lcd.terra.dev,https://lcd.terra-classic.hexxagon.io

# Contract addresses
FACTORY_ADDRESS=terra1...
FEE_DISCOUNT_ADDRESS=terra1...

# Indexer settings
POLL_INTERVAL_MS=6000
START_BLOCK=

# LCD client settings
LCD_TIMEOUT_MS=8000
LCD_COOLDOWN_MS=30000

# API server
API_PORT=3001

# Logging
RUST_LOG=info
