# Network: local | testnet | mainnet
VITE_NETWORK=local

# Contract addresses (run make deploy-local to get these)
VITE_FACTORY_ADDRESS=
VITE_ROUTER_ADDRESS=

# RPC endpoints (defaults per network in constants.ts)
VITE_TERRA_LCD_URL=http://localhost:1317
VITE_TERRA_RPC_URL=http://localhost:26657

# WalletConnect Project ID (required for mobile wallets in production)
VITE_WC_PROJECT_ID=

# Dev mode: enable simulated wallet (no browser extension needed)
VITE_DEV_MODE=true

# Test config
SKIP_INTEGRATION=false
