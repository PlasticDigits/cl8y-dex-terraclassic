# Copy to `.env` and fill values for your network. See docs/frontend.md and docs/environment-matrix.md.

# Network: local | testnet | mainnet
VITE_NETWORK=local

# Contract addresses (run make deploy-local to get these)
VITE_FACTORY_ADDRESS=
VITE_ROUTER_ADDRESS=
VITE_FEE_DISCOUNT_ADDRESS=
VITE_CL8Y_TOKEN_ADDRESS=terra16wtml2q66g82fdkx66tap0qjkahqwp4lwq3ngtygacg5q0kzycgqvhpax3

# Wrapping contracts
VITE_TREASURY_ADDRESS=
VITE_WRAP_MAPPER_ADDRESS=
VITE_LUNC_C_TOKEN_ADDRESS=
VITE_USTC_C_TOKEN_ADDRESS=

# RPC endpoints (defaults per network in constants.ts; localterra uses localhost below)
VITE_TERRA_LCD_URL=http://localhost:1317
VITE_TERRA_RPC_URL=http://localhost:26657

# Indexer HTTP API (charts, volume, trade history, route/solve). Must match indexer API_PORT / deployment.
VITE_INDEXER_URL=http://127.0.0.1:3001

# WalletConnect Project ID (required for mobile wallets in production)
VITE_WC_PROJECT_ID=

# Gas price in uluna (adjust if network fee changes)
VITE_GAS_PRICE_ULUNA=28.325

# Dev mode: enable simulated wallet (no browser extension needed)
VITE_DEV_MODE=true

# Required when VITE_DEV_MODE=true and you use the Simulated Wallet. Must be set via .env.development (gitignored) or
# the shell so it is not pulled into a production bundle. Same phrase as TEST_MNEMONIC in docker/init-chain.sh. deploy-dex-local.sh writes this to .env.development. GitLab #118.
# VITE_DEV_MNEMONIC=

# Test config
SKIP_INTEGRATION=false
